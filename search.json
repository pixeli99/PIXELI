---
layout: null
permalink: /search.json
---
{% assign published_papers = site.papers | where_exp: "p", "p.published != false" %}{% assign published_notes = site.notes | where_exp: "n", "n.published != false" %}{% assign all = published_papers | concat: published_notes | sort: "date" | reverse %}[{% for item in all %}{%- if item.collection == 'papers' -%}{% assign exc = item.content | split: '一句话' | last | split: '<h2' | first | strip_html | strip | truncate: 120 %}{%- else -%}{% assign exc = item.excerpt | strip_html | strip | truncate: 120 %}{%- endif -%}{"id":{{ forloop.index }},"title":{{ item.title | jsonify }},"url":"{{ item.url | relative_url }}","collection":"{{ item.collection }}","date":"{{ item.date | date: '%Y-%m-%d' }}","tags":{{ item.tags | jsonify }},"authors":{{ item.authors | jsonify }},"venue":{{ item.venue | jsonify }},"excerpt":{{ exc | jsonify }},"text":{{ item.content | strip_html | normalize_whitespace | truncate: 1500 | jsonify }}}{% unless forloop.last %},{% endunless %}{% endfor %}]

---
layout: null
permalink: /search.json
sitemap: false
---
{% assign published_papers = site.papers | where_exp: "p", "p.published != false" %}{% assign published_notes = site.notes | where_exp: "n", "n.published != false" %}{% assign all = published_papers | concat: published_notes | sort: "date" | reverse %}[{% for item in all %}{%- if item.collection == 'papers' -%}{%- assign exc = item.description | default: '' -%}{%- if exc.size == 0 -%}{%- assign _bt = item.content | strip_html | normalize_whitespace -%}{%- assign _ba = _bt | split: "一句话 " | last -%}{%- assign exc = _ba | split: " 方法 " | first | strip | truncate: 200, "" -%}{%- else -%}{%- assign exc = exc | truncate: 200 -%}{%- endif -%}{%- else -%}{%- assign exc = item.excerpt | strip_html | strip | truncate: 200 -%}{%- endif -%}{"id":{{ forloop.index }},"title":{{ item.title | jsonify }},"url":"{{ item.url | relative_url }}","collection":"{{ item.collection }}","date":"{{ item.date | date: '%Y-%m-%d' }}","tags":{{ item.tags | jsonify }},"authors":{{ item.authors | jsonify }},"venue":{{ item.venue | jsonify }},"link":{{ item.link | default: "" | jsonify }},"excerpt":{{ exc | jsonify }},"text":{{ item.content | strip_html | normalize_whitespace | truncate: 4000, "" | jsonify }}}{% unless forloop.last %},{% endunless %}{% endfor %}]

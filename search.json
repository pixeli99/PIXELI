---
layout: null
permalink: /search.json
---
{% assign published_papers = site.papers | where_exp: "p", "p.published != false" %}{% assign all = published_papers | concat: site.notes | sort: "date" | reverse %}[{% for item in all %}{"id":{{ forloop.index }},"title":{{ item.title | jsonify }},"url":"{{ item.url | relative_url }}","collection":"{{ item.collection }}","tags":{{ item.tags | jsonify }},"text":{{ item.content | strip_html | normalize_whitespace | truncate: 600 | jsonify }}}{% unless forloop.last %},{% endunless %}{% endfor %}]
